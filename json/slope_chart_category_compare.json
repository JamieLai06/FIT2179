{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": {
    "text": "Malaysia CPI Category Change (2020 → 2026)",
    "subtitle": "Average CPI growth across spending categories",
    "anchor": "start",
    "fontSize": 18,
    "color": "#000000",
    "font": "Serif"
  },
  "width": "container",
  "height": 500,
  "data": {
    "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_3d_categorized.csv"
  },
  "transform": [
    {
      "calculate": "year(toDate(datum.date))",
      "as": "year_num"
    },
    {
      "filter": "datum.year_num == 2020 || datum.year_num == 2026"
    },
    {
      "filter": "isValid(datum.index)"
    },
    {
      "aggregate": [
        {
          "op": "mean",
          "field": "index",
          "as": "avg_cpi"
        }
      ],
      "groupby": ["category", "year_num"]
    },
    {
      "calculate": "toString(datum.year_num)",
      "as": "year"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "sort": ["2020", "2026"],
          "title": null
        },
        "y": {
          "field": "avg_cpi",
          "type": "quantitative",
          "title": "Average CPI Index"
        },
        "detail": {
          "field": "category"
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {"scheme": "category20b"},
          "title": "Category",
          "legend": {
            "orient": "bottom",
            "columns": 3,
            "labelFontSize": 11
          }
        },
        "tooltip": [
          {"field": "category", "type": "nominal", "title": "Category"},
          {"field": "year", "type": "nominal", "title": "Year"},
          {"field": "avg_cpi", "type": "quantitative", "title": "Average CPI", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 120
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "sort": ["2020", "2026"]
        },
        "y": {
          "field": "avg_cpi",
          "type": "quantitative"
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {"scheme": "category20b"},
          "legend": null
        },
        "tooltip": [
          {"field": "category", "type": "nominal"},
          {"field": "year", "type": "nominal"},
          {"field": "avg_cpi", "type": "quantitative", "format": ".1f"}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "axis": {"grid": true}
  }
}
