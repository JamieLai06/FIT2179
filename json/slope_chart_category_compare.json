{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },

  "title": {
    "text": "Malaysia CPI Category Change (2020 → 2026)",
    "subtitle": "Average CPI growth across spending categories",
    "anchor": "start",
    "fontSize": 18,
    "color": "#1a365d"
  },

  "width": "container",
  "height": 500,

  "data": {
    "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_3d_categorized.csv"
  },

  "transform": [

    {
      "calculate": "year(toDate(datum.date))",
      "as": "year_num"
    },

    {
      "filter": "datum.year_num == 2020 || datum.year_num == 2026"
    },

    {
      "filter": "isValid(datum.index)"
    },

    {
      "aggregate": [
        {
          "op": "mean",
          "field": "index",
          "as": "avg_cpi"
        }
      ],

      "groupby": [
        "category",
        "year_num"
      ]
    },

    {
      "calculate": "toString(datum.year_num)",
      "as": "year"
    }
  ],

  "layer": [

    {
      "mark": {
        "type": "line",
        "strokeWidth": 3
      },

      "encoding": {

        "x": {
          "field": "year",
          "type": "ordinal",
          "sort": ["2020", "2026"],
          "title": null
        },

        "y": {
          "field": "avg_cpi",
          "type": "quantitative",
          "title": "Average CPI Index"
        },

        "detail": {
          "field": "category"
        },

        "color": {
          "field": "category",
          "type": "nominal",
          "title": "Category"
        },

        "tooltip": [
          {
            "field": "category",
            "type": "nominal",
            "title": "Category"
          },
          {
            "field": "year",
            "type": "nominal",
            "title": "Year"
          },
          {
            "field": "avg_cpi",
            "type": "quantitative",
            "title": "Average CPI",
            "format": ".1f"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "circle",
        "size": 120
      },

      "encoding": {

        "x": {
          "field": "year",
          "type": "ordinal",
          "sort": ["2020", "2026"]
        },

        "y": {
          "field": "avg_cpi",
          "type": "quantitative"
        },

        "color": {
          "field": "category",
          "type": "nominal",
          "legend": null
        },

        "tooltip": [
          {
            "field": "category",
            "type": "nominal"
          },
          {
            "field": "year",
            "type": "nominal"
          },
          {
            "field": "avg_cpi",
            "type": "quantitative",
            "format": ".1f"
          }
        ]
      }
    },

    {
      "transform": [
        {
          "filter": "datum.year == '2026'"
        }
      ],

      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 11
      },

      "encoding": {

        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "y": {
          "field": "avg_cpi",
          "type": "quantitative"
        },

        "text": {
          "field": "category"
        },

        "color": {
          "field": "category",
          "type": "nominal",
          "legend": null
        }
      }
    }
  ],

  "config": {

    "view": {
      "stroke": null
    },

    "axis": {
      "grid": true
    }
  }
}