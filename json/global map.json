{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Global Cost of Living Index 2026",
    "subtitle": "Relative to New York City (Index = 100). Higher values indicate higher costs.",
    "anchor": "start"
  },
  "width": 800,
  "height": 450,
  "data": {
    "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/7_map/js/ne_110m_admin_0_countries.json",
    "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
  },
  "transform": [
    {
      "lookup": "properties.NAME",
      "from": {
        "data": {
          "url": "country_cost_of_living.csv"
        },
        "key": "country",
        "fields": ["cost_of_living_index"]
      }
    },
    {"calculate": "datum.cost_of_living_index ? datum.cost_of_living_index : 0", "as": "Index"}
  ],
  "projection": {"type": "equalEarth"},
  "mark": {"type": "geoshape", "stroke": "white"},
  "encoding": {
    "color": {
      "field": "Index",
      "type": "quantitative",
      "scale": {
        "type": "threshold",
        "domain": [20, 40, 60, 80],
        "scheme": "reds"
      },
      "title": "Cost Index"
    },
    "tooltip": [
      {"field": "properties.NAME", "type": "nominal", "title": "Country"},
      {"field": "cost_of_living_index", "type": "quantitative", "title": "Cost of Living Index"}
    ]
  }
}
