{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "autosize": {
    "type": "fit",
    "contains": "padding"
  },

  "title": {
    "text": "The 6-Year Inflation Map (2020-2026)",
    "subtitle": "Average CPI Index by Category over Time",
    "anchor": "start",
    "fontSize": 18
  },
  "width": "container",
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_3d_categorized.csv",
    "format": {"type": "csv", "parse": {"date": "date:'%d/%m/%Y'"}}
  },
  "transform": [
    {
      "calculate": "year(datum.date)",
      "as": "year_field"
    },
    {
      "aggregate": [{"op": "mean", "field": "index", "as": "avg_index"}],
      "groupby": ["category", "year_field"]
    }
  ],
  "encoding": {
    "x": {
      "field": "year_field",
      "type": "ordinal",
      "title": "Year",
      "axis": {"labelAngle": 0}
    },
    "y": {
      "field": "category",
      "type": "nominal",
      "title": "Category",
      "sort": "descending"
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rect",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "avg_index",
          "type": "quantitative",
          "scale": {"scheme": "blues", "reverse": true},
          "title": "Avg Index"
        },
        "tooltip": [
          {"field": "year_field", "title": "Year"},
          {"field": "category", "title": "Category"},
          {"field": "avg_index", "title": "Avg Index", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 11},
      "encoding": {
        "color": {
          "condition": {"test": "datum.avg_index > 135", "value": "white"},
          "value": "black"
        }
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent"},
    "axis": {"domain": false}
  }
}