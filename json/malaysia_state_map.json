{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 500,
  
  "params": [
    {
      "name": "year_filter",
      "value": 2020,
      "bind": {
        "input": "range",
        "min": 2020,
        "max": 2025,
        "step": 1,
        "name": "Select Year: "
      }
    }
  ],
  "projection": {
    "type": "equirectangular",
    "center": [108.2, 4.05],
    "scale": 3500
  },
  "layer": [
    {
      "description": "Layer 1: Your dedicated Ocean Feature",
      "data": {
        "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/json/ne_10m.json",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_ocean"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#d9eaf7",
        "stroke": null
      }
    },
    {
      "description": "Layer 2: Surrounding Land / Neighboring Countries",
      "data": {
        "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/json/ne_10m.json",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },
      "transform": [
        {
          "filter": "datum.properties.iso_a2 !== 'MY'"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#fffcfc",
        "stroke": "#cccccc",
        "strokeWidth": 0.4
      }
    },
    {
      "description": "Layer 3: Malaysia State Choropleth Map",
      "data": {
        "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_state.csv"
      },
      "transform": [
        {
          "calculate": "parseInt(split(datum.date, '/')[length(split(datum.date, '/')) - 1])",
          "as": "extracted_year"
        },
        {
          "filter": "datum.extracted_year == year_filter"
        },
        {
          "lookup": "state",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/json/ne_10m.json",
              "format": {
                "type": "topojson",
                "feature": "ne_10m_admin_1_states_provinces"
              }
            },
            "key": "properties.name"
          },
          "as": "geo"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "shape": {
          "field": "geo",
          "type": "geojson"
        },
        "color": {
          "field": "index",
          "type": "quantitative",
          "aggregate": "mean",
          "scale": {
            "scheme": "reds"
          },
          "title": "Average Index"
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "extracted_year",
            "type": "quantitative",
            "title": "Year"
          },
          {
            "field": "index",
            "type": "quantitative",
            "aggregate": "mean",
            "title": "Avg Index Value",
            "format": ".1f"
          }
        ]
      }
    }
  ]
}
