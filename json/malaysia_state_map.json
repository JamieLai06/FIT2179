{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },

  "width": "container",
  "height": 450,
  "padding": 20,

  "title": {
    "text": "Cost of Living Across Malaysian States",
    "subtitle": "Consumer Price Index (CPI) by state"
  },

  "params": [
    {
      "name": "zoom",
      "value": 1600,
      "bind": {
        "input": "range",
        "min": 1200,
        "max": 4000,
        "step": 100,
        "name": "Zoom: "
      }
    }
  ],

  "projection": {
    "type": "mercator",
    "center": [109.5, 4.5],
    "scale": {
      "expr": "zoom"
    }
  },

  "layer": [

    {
      "data": {
        "sphere": true
      },

      "mark": {
        "type": "geoshape",
        "fill": "#f0f8ff"
      }
    },

    {
      "data": {
        "graticule": {
          "step": [5, 5]
        }
      },

      "mark": {
        "type": "geoshape",
        "stroke": "#d9d9d9",
        "strokeWidth": 0.5
      }
    },

    {
      "data": {
        "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/main/json/ne_10m_admin_1_states_provinces.json",

        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },

      "transform": [

        {
          "lookup": "properties.name",

          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/main/dataset/cleaned_cpi_state.csv"
            },

            "key": "state",

            "fields": [
              "index"
            ]
          }
        }

      ],

      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1
      },

      "encoding": {

        "color": {

          "condition": {

            "test": "datum.properties.admin == 'Malaysia' && datum.index != null",

            "field": "index",
            "type": "quantitative",

            "title": "CPI Index",

            "scale": {
              "scheme": "blues"
            }
          },

          "value": "#e0e0e0"
        },

        "tooltip": [

          {
            "field": "properties.name",
            "type": "nominal",
            "title": "State / Province"
          },

          {
            "field": "properties.admin",
            "type": "nominal",
            "title": "Country"
          },

          {
            "field": "index",
            "type": "quantitative",
            "title": "CPI Index",
            "format": ".1f"
          }
        ]
      }
    }

  ],

  "config": {

    "background": "white",

    "view": {
      "stroke": null
    },

    "title": {
      "fontSize": 24,
      "subtitleFontSize": 13,
      "anchor": "start"
    },

    "legend": {
      "titleFontSize": 13,
      "labelFontSize": 11
    }
  }
}
