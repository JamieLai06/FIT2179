{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": {
    "text": "Cost of Living Across Malaysian States",
    "subtitle": "Consumer Price Index (CPI) by state",
    "anchor": "middle",
    "fontSize": 18,
    "fontWeight": "bold",
    "offset": 20
  },
  "width": "container",
  "height": 450,
  "data": {
    "url": "https://cdn.jsdelivr.net/gh/JamieLai06/FIT2179@main/json/ne_10m%20(1).json",
    "format": {
      "type": "topojson",
      "feature": "ne_10m_admin_1_states_provinces"
    }
  },
  "projection": {
    "type": "equirectangular",
    "center": [109.5, 4.2],
    "scale": 2000
  },
  "layer": [
    {
      "comment": "LAYER 1: Draws all background countries/states in neutral white",
      "mark": {
        "type": "geoshape",
        "fill": "#ffffff",
        "stroke": "#dbdfdf",
        "strokeWidth": 0.5
      }
    },
    {
      "comment": "LAYER 2: CPI data overlay with custom tooltips",
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_state.csv"
            },
            "key": "state",
            "fields": ["index"]
          }
        },
        {
          "filter": "datum.index != null"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1.2
      },
      "encoding": {
        "color": {
          "field": "index",
          "type": "quantitative",
          "title": "CPI Index",
          "scale": {
            "type": "linear",
            "scheme": "reds"
          },
          "legend": {
            "orient": "right",
            "titleAnchor": "start"
          }
        },
        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "index",
            "type": "quantitative",
            "title": "Normalised CPI Index",
            "format": ".2f"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": "#d9eaf7"
  }
}
