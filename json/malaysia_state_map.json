{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 440,
  "projection": {
    "type": "equirectangular",
    "center": [108.2, 4.05],
    "scale": 3000
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/json/ne_10m.json",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_ocean"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#d9eaf7",
        "stroke": null
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/json/ne_10m.json",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },
      "transform": [
        {
          "filter": "datum.properties.admin == 'Malaysia'"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#ffffff",
        "stroke": "#dbdfdf",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/json/ne_10m.json",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },
      "transform": [
        {
          "filter": "datum.properties.admin == 'Malaysia'"
        },
        {
          "lookup": "properties.name",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_state.csv"
            },
            "key": "state",
            "fields": ["index"]
          }
        },
        {
          "filter": "datum.index != null"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1.2
      },
      "encoding": {
        "color": {
          "field": "index",
          "type": "quantitative",
          "title": "CPI Index",
          "scale": {
            "type": "linear",
            "scheme": "reds"
          },
          "legend": {
            "orient": "right",
            "titleAnchor": "start",
            "offset": 30
          }
        },
        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "index",
            "type": "quantitative",
            "title": "Normalised CPI Index",
            "format": ".2f"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  }
}
