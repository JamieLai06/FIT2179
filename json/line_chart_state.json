{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "width": "container",
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_state.csv"
  },
  "params": [
    {
      "name": "SelectState",
      "value": "Selangor",
      "bind": {
        "input": "select",
        "options": [
          "Johor", "Kedah", "Kelantan", "Kuala Lumpur", "Labuan", "Melaka", 
          "Negeri Sembilan", "Pahang", "Penang", "Perak", "Perlis", "Putrajaya", 
          "Sabah", "Sarawak", "Selangor", "Terengganu"
        ],
        "name": "Region: "
      }
    }
  ],
  "layer": [
    {
      "description": "Base Layer: Grey ghost lines for other states",
      "mark": {"type": "line", "color": "#e2e8f0", "strokeWidth": 1.5, "opacity": 0.5},
      "encoding": {
        "x": {"field": "date", "type": "temporal", "title": "Year", "axis": {"grid": false}},
        "y": {"field": "index", "type": "quantitative", "scale": {"domain": [100, 150]}, "title": "CPI Index"},
        "detail": {"field": "state"}
      }
    },
    {
      "description": "Highlight Layer: Bold Blue line for selected state",
      "transform": [{"filter": "datum.state == SelectState"}],
      "mark": {"type": "line", "color": "#98c1ec", "strokeWidth": 4, "interpolate": "monotone"},
      "encoding": {
        "x": {"field": "date", "type": "temporal"},
        "y": {"field": "index", "type": "quantitative"}
      }
    },
    {
      "description": "The 'Hover Dot': Circles that only appear on mouseover",
      "transform": [{"filter": "datum.state == SelectState"}],
      "params": [
        {
          "name": "hover",
          "select": {"type": "point", "on": "mouseover", "nearest": true, "fields": ["date"]}
        }
      ],
      "mark": {"type": "circle", "color": "#6daff4", "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "x": {"field": "date", "type": "temporal"},
        "y": {"field": "index", "type": "quantitative"},
        "size": {
          "condition": {"param": "hover", "empty": false, "value": 150},
          "value": 0
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "date", "type": "temporal", "title": "Month", "format": "%B %Y"},
          {"field": "index", "title": "CPI Index", "format": ".1f"}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent"},
    "font": "Inter"
  }
}
