{
  "$schema": "https://vega.github.io/schema/vega/v5.json",

  "autosize": {
  "type": "fit",
  "contains": "padding"
},
  
  "width": 1400,
  "height": 600,
  "padding": {"top": 20, "left": 10, "right": 5, "bottom": 20},

  "title": {
    "text": "2026 Budget Hierarchy: Sub-category CPI Breakdown",
    "subtitle": "Area represents CPI Index | Hover for details",
    "anchor": "start",
    "fontSize": 22,
    "fontWeight": "bold",
    "offset": 30
  },

  "data": [
    {
      "name": "raw_data",
      "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/main/dataset/cleaned_cpi_3d_categorized.csv",
      "format": {"type": "csv", "parse": {"index": "number", "date": "date:'%d/%m/%Y'"}},
      "transform": [
        {
          "type": "filter",
          "expr": "year(datum.date) == 2026 && datum.index != null"
        },
        {
          "type": "aggregate",
          "ops": ["mean"],
          "fields": ["index"],
          "as": ["avg_index"],
          "groupby": ["category", "sub-category"]
        }
      ]
    },
    {
      "name": "tree",
      "source": "raw_data",
      "transform": [
        {
          "type": "nest",
          "keys": ["category", "sub-category"]
        },
        {
          "type": "treemap",
          "field": "avg_index",
          "sort": {"field": "value", "order": "descending"},
          "round": true,
          "method": "squarify",
          "size": [{"signal": "width"}, {"signal": "height"}]
        }
      ]
    },
    {
      "name": "leaves",
      "source": "tree",
      "transform": [{ "type": "filter", "expr": "!datum.children" }]
    }
  ],

  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "leaves", "field": "category"},
      "range": [
        "#ADAAF0", "#C69AEF", "#9AE5EF", "#eeca3b", "#b279a2", "#F5C2EC", "#E7E773","#E7B573",
        "#A34F00", "#54a24b", "#9c755f", "#bab0ac", "#AAC0F0"
      ]
    }
  ],

  "legends": [
    {
      "fill": "color",
      "title": "Expenditure Categories",
      "orient": "right",
      "columns": 1,
      "symbolType": "square",
      "labelFontSize": 12,
      "titleFontSize": 14,
      "offset": 40
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "leaves"},
      "encode": {
        "enter": {
          "stroke": {"value": "#ffffff"},
          "strokeWidth": {"value": 1.5},
          "tooltip": {
            "signal": "{'Category': datum.category, 'Sub-category': datum['sub-category'], 'Avg CPI': format(datum.avg_index, '.1f')}"
          }
        },
        "update": {
          "x": {"field": "x0"}, "y": {"field": "y0"},
          "x2": {"field": "x1"}, "y2": {"field": "y1"},
          "fill": {"scale": "color", "field": "category"}
        },
        "hover": {
          "fillOpacity": {"value": 0.6}
        }
      }
    }
  ]
}
