{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "autosize": {
    "type": "fit",
    "contains": "padding"
  },

  "width": "container",
  "height": 470,

  "data": {
    "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/main/dataset/cleaned_cpi_annual.csv"
  },

  "transform": [
    {
      "calculate": "year(toDate(datum.date))",
      "as": "Year"
    },

    {
      "calculate": "toNumber(datum.index)",
      "as": "CPI"
    }
  ],

  "layer": [

    {
      "mark": {
        "type": "area",
        "color": "#7482ee",
        "opacity": 0.3
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": "Year"
        },

        "y": {
          "field": "CPI",
          "type": "quantitative",
          "title": "CPI Index",
          "scale": {
            "zero": false
          }
        },

        "tooltip": [
          {
            "field": "Year",
            "type": "ordinal"
          },
          {
            "field": "CPI",
            "type": "quantitative",
            "title": "CPI Index"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "line",
        "stroke": "#050573",
        "strokeWidth": 3
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },

        "y": {
          "field": "CPI",
          "type": "quantitative"
        }
      }
    },

    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 80,
        "color": "#201cab"
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },

        "y": {
          "field": "CPI",
          "type": "quantitative"
        }, 
        "tooltip": [
        {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
        },
        {
            "field": "CPI",
            "type": "quantitative",
            "title": "CPI Index"
        }
        ]
      }
    },

    {
      "data": {
        "values": [
          {
            "Year": 2020,
            "CPI": 120.1
          }
        ]
      },

      "mark": {
        "type": "rule",
        "color": "#555",
        "strokeDash": [4,4]
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "Year": 2020,
            "CPI": 120.1,
            "label": "2020: COVID-19 slowdown"
          }
        ]
      },

      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "dy": -35,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#333"
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },

        "y": {
          "field": "CPI",
          "type": "quantitative"
        },

        "text": {
          "field": "label"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "Year": 2023,
            "CPI": 130.4
          }
        ]
      },

      "mark": {
        "type": "rule",
        "color": "#555",
        "strokeDash": [4,4]
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "Year": 2023,
            "CPI": 130.4,
            "label": "2023: Inflation surge"
          }
        ]
      },

      "mark": {
        "type": "text",
        "align": "right",
        "dx": -10,
        "dy": -35,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#333"
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },

        "y": {
          "field": "CPI",
          "type": "quantitative"
        },

        "text": {
          "field": "label"
        }
      }
    }

  ],

  "config": {
    "background": "white",

    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13
    },

    "title": {
      "fontSize": 22,
      "subtitleFontSize": 13,
      "anchor": "start"
    }
  }
}
