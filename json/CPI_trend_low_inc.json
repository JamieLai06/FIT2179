{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },

  "title": {
    "text": "CPI Trend for Low-Income Households (2020-2026)",
    "anchor": "start",
    "fontSize": 16
  },
  "width": "container",
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_2d_lowincome_with_desc.csv",
    "format": {
      "type": "csv",
      "parse": {"date": "date:'%m/%d/%Y'"}
    }
  },
  "transform": [
    {"filter": "datum.description == 'All items'"}
  ],
  "layer": [
    {
      "mark": {"type": "line", "color": "#1f77b4", "strokeWidth": 3},
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": "Year",
          "axis": {
            "format": "%Y",
            "tickCount": "year",
            "labelFlush": true,
            "grid": true
          }
        },
        "y": {
          "field": "index",
          "type": "quantitative",
          "title": "CPI Index",
          "scale": {"zero": false}
        }
      }
    },
    {
      "mark": {"type": "text", "dy": 6.5, "fontWeight": "bold", "color": "#d62728"},
      "encoding": {
        "x": {"datum": {"year": 2020, "month": 3, "date": 1}, "type": "temporal"},
        "y": {"datum": 118.8, "type": "quantitative"},
        "text": {"value": "2020 Lockdown Dip"}
      }
    },
    {
      "mark": {"type": "rule", "color": "#d62728", "strokeDash": [4, 2]},
      "encoding": {
        "x": {"datum": {"year": 2020, "month": 3, "date": 1}, "type": "temporal"},
        "y": {"datum": 118.8, "type": "quantitative"},
        "y2": {"datum": 121, "type": "quantitative"}
      }
    },
    {
      "mark": {"type": "text", "dy": -60, "dx": -20, "fontWeight": "bold", "color": "#ff7f0e"},
      "encoding": {
        "x": {"datum": {"year": 2022, "month": 0, "date": 1}, "type": "temporal"},
        "y": {"datum": 123.6, "type": "quantitative"},
        "text": {"value": "2022 Inflation Surge"}
      }
    },
    {
      "mark": {"type": "rule", "color": "#ff7f0e", "strokeDash": [6, 4]},
      "encoding": {
        "x": {"datum": {"year": 2022, "month": 0, "date": 1}, "type": "temporal"},
        "y": {"datum": 123.6, "type": "quantitative"},
        "y2": {"datum": 126, "type": "quantitative"}
      }
    }
  ],
  "config": {
    "axis": {"labelFontSize": 12, "titleFontSize": 14}
  }
}