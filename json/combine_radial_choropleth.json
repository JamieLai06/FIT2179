{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "spacing": 20,
  "bounds": "flush",
  "title": {
    "text": "Click the legend at the radial chart to highlight the country",
    "fontSize": 15,
    "color": "#000000",
    "anchor": "middle",
    "dy": -10
  },
  "hconcat": [
    {
      "title": "Geographic Distribution",
      "width": 900,
      "height": 450,
      "projection": {
        "type": "equirectangular"
      },
      "layer": [
        {
          "data": {"sphere": true},
          "mark": {"type": "geoshape", "fill": "#f0f8ff"}
        },
        {
          "data": {"graticule": {"step": [40, 40]}},
          "mark": {"type": "geoshape", "stroke": "#b8c6d1", "strokeWidth": 0.6}
        },
        {
          "data": {
            "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/json/ne_10m_admin_0_countries.json",
            "format": {"type": "topojson", "feature": "ne_10m_admin_0_countries"}
          },
          "transform": [
            {
              "lookup": "properties.NAME",
              "from": {
                "data": {
                  "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_globaldata.csv"
                },
                "key": "Country",
                "fields": ["Cost of Living Index", "Country"]
              }
            },
            {
              "calculate": "toNumber(datum['Cost of Living Index'])",
              "as": "Cost_Index"
            }
          ],
          "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 0.5},
          "encoding": {
            "color": {
              "field": "Cost_Index",
              "type": "quantitative",
              "scale": {"scheme": "reds"},
              "legend": {
                "title": "Cost of Living Index",
                "orient": "bottom",
                "direction": "horizontal",
                "gradientLength": 250,
                "gradientThickness": 15,
                "titleFontSize": 12,
                "labelFontSize": 10
              }
            },
            "opacity": {
              "condition": {
                "param": "countrySelection", 
                "empty": true,
                "value": 1
              },
              "value": 0.1
            },
            "tooltip": [
              {"field": "Country", "type": "nominal"},
              {"field": "Cost_Index", "type": "quantitative", "format": ".1f"}
            ]
          }
        }
      ]
    },
    {
      "title": "Top 10 Most Expensive Nations",
      "width": 400,
      "height": 450,
      "data": {
        "url": "https://raw.githubusercontent.com/JamieLai06/FIT2179/refs/heads/main/dataset/cleaned_cpi_globaldata.csv"
      },
      "params": [
        {
          "name": "countrySelection",
          "select": {"type": "point", "fields": ["Country"]},
          "bind": "legend"
        }
      ],
      "transform": [
        {"calculate": "toNumber(datum['Cost of Living Index'])", "as": "Cost_Index"},
        {
          "window": [{"op": "rank", "as": "rank"}],
          "sort": [{"field": "Cost_Index", "order": "descending"}]
        },
        {"filter": "datum.rank <= 10"}
      ],
      "mark": {
        "type": "arc",
        "innerRadius": 60,
        "stroke": "#fff",
        "cursor": "pointer"
      },
      "encoding": {
        "theta": {"field": "Cost_Index", "type": "quantitative", "stack": true},
        "radius": {
          "field": "Country",
          "scale": {"type": "band", "rangeMin": 70, "rangeMax": 160},
          "sort": {"field": "Cost_Index", "order": "descending"}
        },
        "color": {
          "field": "Country",
          "type": "nominal",
          "scale": {
            "range": [
              "#eeca3b", "#b279a2", "#F5C2EC", "#E7E773", "#E7B573",
              "#A34F00", "#ADAAF0", "#9c755f", "#bab0ac", "#AAC0F0"
            ]
          },
          "sort": {"field": "Cost_Index", "order": "descending"},
          "legend": {
            "title": "Country",
            "orient": "right",
            "offset": 0,
            "labelFontSize": 11
          }
        },
        "opacity": {
          "condition": {"param": "countrySelection", "value": 1},
          "value": 0.2
        },
        "tooltip": [
          {"field": "Country", "type": "nominal"},
          {"field": "Cost_Index", "type": "quantitative", "format": ".1f"}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": null}
  }
}
